rules_version = '2';

// All client access goes through Cloud Functions (which use the Admin SDK and
// bypass these rules). Direct client access to Firestore is therefore fully
// denied — no one can enumerate URLs or configs from the browser.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
